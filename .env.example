# ── Storage ─────────────────────────────────────────────────────────────────
DB_PATH=godwit_vane.db
MODEL_DIR=.

# ── Notifications (Apprise) ─────────────────────────────────────────────────
# Comma-separated Apprise URLs. Examples:
#   discord://webhook_id/webhook_token
#   tgram://bot_token/chat_id
#   slack://tokenA/tokenB/tokenC
#   ntfys://ntfy.example.com/my-topic
#   mailto://user:pass@smtp.example.com?to=me@example.com
# Full list: https://github.com/caronc/apprise/wiki
APPRISE_URLS=

# ── Radar (exact-match brand/content alerts) ────────────────────────────────
# Comma-separated keywords. Matches on posts + comments across configured channels.
CONTENT_KEYWORDS=example-brand,example-product

# ── Labeller ────────────────────────────────────────────────────────────────
# "ollama" (local, free; required for Reddit per core-009) or
# "anthropic" (cloud; used only for non-Reddit sources).
LABELLER=ollama

# Ollama — always built; Reddit labels are pinned to Ollama regardless of LABELLER.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3.5

# Anthropic — used as default labeller when LABELLER=anthropic (non-Reddit sources).
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Reddit source config ────────────────────────────────────────────────────
# Default: "public" (RSS + JSON, no auth, ~10 QPM). Set "praw" for OAuth mode
# once implemented.
REDDIT_MODE=public
REDDIT_USER_AGENT=Godwit-Vane/1.0 (by u/your_username)
REDDIT_QPS=0.15
REDDIT_BURST=3

# ── Channels and pre-filters ────────────────────────────────────────────────
# Configured in src/signals/settings.json (channels per source, per-channel
# pre-filter rules, scan interval, trend report time, retention days).
