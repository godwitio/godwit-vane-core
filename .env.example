# ── Storage ─────────────────────────────────────────────────────────────────
DB_PATH=godwit_vane.db
MODEL_DIR=./.model

# ── Logging ─────────────────────────────────────────────────────────────────
# "info" (default) or "debug" for verbose per-item diagnostics.
LOG_LEVEL=info

# Daily-rotated log file. `{date}` is replaced with YYYY-MM-DD per the local
# clock. The sink reopens at midnight and prunes older matches; LOG_RETENTION_DAYS
# is inclusive of today (5 = today + 4 prior days). A template without `{date}`
# disables rotation (e.g. LOG_FILE_TEMPLATE=log.txt).
# Override per-invocation with --log-file / --log-retention-days.
LOG_FILE_TEMPLATE=log.{date}.txt
LOG_RETENTION_DAYS=5

# ── Labeller ────────────────────────────────────────────────────────────────
# Labeller for ALL sources (post content is sent to whichever you pick):
#   "ollama"    — local, free, nothing leaves the host.
#   "anthropic" — cloud; post content is sent to Anthropic per their API terms.
# Choose deliberately: routing follows this setting, no per-source pinning.
LABELLER=ollama

# Ollama — used when LABELLER=ollama.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Anthropic — used when LABELLER=anthropic.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── Reddit source config ────────────────────────────────────────────────────
# Default: "public" (RSS + JSON, no auth, ~10 QPM). Set "praw" for OAuth mode
# once implemented.
REDDIT_MODE=public
REDDIT_USER_AGENT=Godwit-Vane/1.0 (by u/your_username)
REDDIT_QPS=0.15
REDDIT_BURST=3

# ── Channels and pre-filters ────────────────────────────────────────────────
# Configured in src/signals/settings.json (channels per source, per-channel
# pre-filter rules, scan interval, trend report time, retention days).

# ── Training seed bootstrap (Brave Search) ──────────────────────────────────
# One-shot historical backfill on fresh installs. When enabled, runs at
# monitor.py startup, queries Brave Search for /r/<channel> posts matching
# signal keywords, enqueues them through the normal Reddit enrich pipeline.
# Run-once per (channel, signal) pair, tracked in the seeding_state table.
# Get an API key: https://api-dashboard.search.brave.com/
# The free "Data for Search" tier allows 1 QPS and 2000 queries/month.
BRAVE_SEED_ENABLED=false
BRAVE_SEARCH_API_KEY=
BRAVE_SEARCH_QPS=0.5
BRAVE_SEARCH_MAX_AGE_DAYS=365
